def calcular_media(nota1, nota2):
    media = (nota1 + nota2) / 2

    print(f"Média: {media}")

    if media >= 7:
        print("Aprovado!")
    else:
        print("Reprovado!")


nota1 = float(input("Digite a primeira nota: "))
nota2 = float(input("Digite a segunda nota: "))

calcular_media(nota1, nota2)